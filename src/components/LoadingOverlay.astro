---
---
<div id="nav-loading-overlay" class="nav-loading-overlay" aria-hidden="true">
  <div class="nav-loading-inner">
    <div class="nav-loading-spinner" aria-hidden="true"></div>
    <span class="nav-loading-label">Loading</span>
  </div>
</div>

<style>
  .nav-loading-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(14, 14, 14, 0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 150ms ease-out;
  }

  .nav-loading-overlay.active {
    opacity: 1;
    pointer-events: all;
  }

  .nav-loading-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    padding: 2rem 3rem;
    background: rgba(32, 31, 31, 0.7);
    border-radius: 1rem;
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.5);
  }

  .nav-loading-spinner {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    position: relative;
    background:
      conic-gradient(
        from 0deg,
        transparent 0%,
        #00e0b3 60%,
        #00ffcc 100%
      );
    mask: radial-gradient(circle at center, transparent 55%, #000 57%);
    -webkit-mask: radial-gradient(circle at center, transparent 55%, #000 57%);
    animation: nav-loading-spin 900ms linear infinite;
    box-shadow: 0 0 24px rgba(0, 224, 179, 0.35);
  }

  .nav-loading-label {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #b9cbc2;
  }

  @keyframes nav-loading-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-loading-overlay {
      transition: none;
    }
    .nav-loading-spinner {
      animation-duration: 2s;
    }
  }
</style>

<script>
  const overlay = document.getElementById("nav-loading-overlay");
  if (overlay) {
    const showOverlay = () => {
      overlay.classList.add("active");
      overlay.setAttribute("aria-hidden", "false");
    };

    const hideOverlay = () => {
      overlay.classList.remove("active");
      overlay.setAttribute("aria-hidden", "true");
    };

    const isExternalLink = (href, target) => {
      if (!href) return false;
      if (target === "_blank") return false;
      if (href.startsWith("#")) return false;
      if (href.startsWith("mailto:") || href.startsWith("tel:")) return false;
      return true;
    };

    document.addEventListener(
      "click",
      (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const anchor = target.closest("a");
        if (!anchor) return;
        const href = anchor.getAttribute("href");
        const linkTarget = anchor.getAttribute("target");
        if (!isExternalLink(href, linkTarget)) return;
        if (
          event.defaultPrevented ||
          event.ctrlKey ||
          event.metaKey ||
          event.shiftKey ||
          event.altKey ||
          event.button !== 0
        ) {
          return;
        }
        showOverlay();
      },
      true
    );

    window.addEventListener("pageshow", hideOverlay);
    window.addEventListener("astro:after-swap", hideOverlay);
    window.addEventListener("beforeunload", () => {
      setTimeout(hideOverlay, 100);
    });
  }
</script>
