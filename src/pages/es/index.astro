---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteConfig } from "../../data/site";
import { catalogs } from "../../data/catalogs";
import { demos } from "../../data/demos";
import { t } from "../../data/i18n.js";

const locale = "es";
const site = siteConfig[locale];
const catalogList = catalogs[locale];
const demoList = demos[locale];
const [firstCatalog, ...restCatalogs] = catalogList;
---
<BaseLayout
  title={site.title}
  navTitle={site.title}
  locale={locale}
  translationPath="/"
>
  <section class="hero">
    <span class="eyebrow">{t(locale, "hero.eyebrow")}</span>
    <h1 class="display-large">
      {t(locale, "hero.titleLine1")}<br />{t(locale, "hero.titleLine2")}<br />
      <span class="mint-underline">{t(locale, "hero.titleAccent")}</span>
    </h1>
    <p class="lead">{site.description}</p>
  </section>

  <section>
    <div class="section-header">
      <h2 class="headline-medium">{t(locale, "section.catalogs.title")}</h2>
      <p>{t(locale, "section.catalogs.description")}</p>
    </div>
    <div class="bento">
      <a class="card wide featured" href={firstCatalog.href}>
        <span class="tag">{t(locale, "tag.catalogFlagship")}</span>
        <h3>{firstCatalog.title}</h3>
        <p>{firstCatalog.description}</p>
        <div class="card-meta">
          <span class="label">{t(locale, "cta.explore")}</span>
          <span class="card-arrow">&rarr;</span>
        </div>
      </a>
      {restCatalogs.map((catalog) => (
        <a class="card" href={catalog.href}>
          <span class="tag">{t(locale, "tag.catalog")}</span>
          <h3>{catalog.title}</h3>
          <p>{catalog.description}</p>
          <div class="card-meta">
            <span class="label">{t(locale, "cta.explore")}</span>
            <span class="card-arrow">&rarr;</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  {demoList.length > 0 && (
    <section>
      <div class="section-header">
        <h2 class="headline-medium">{t(locale, "section.exampleApps.title")}</h2>
        <p>{t(locale, "section.exampleApps.description")}</p>
      </div>
      <div class="bento">
        {demoList.map((demo) => (
          <a class="card" href={demo.href}>
            <span class="tag">{demo.category || t(locale, "tag.demo")}</span>
            <h3>{demo.title}</h3>
            <p>{demo.description}</p>
            <div class="card-meta">
              <span class="label">{t(locale, "cta.open")}</span>
              <span class="card-arrow">&rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <section>
    <div class="section-header">
      <h2 class="headline-medium">{t(locale, "section.learn.title")}</h2>
      <p>{t(locale, "section.learn.description")}</p>
    </div>
    <div class="bento">
      <a class="card wide featured" href="/es/guide/">
        <span class="tag">{t(locale, "tag.guide")}</span>
        <h3>{t(locale, "learn.guide.title")}</h3>
        <p>{t(locale, "learn.guide.description")}</p>
        <div class="card-meta">
          <span class="label">{t(locale, "cta.read")}</span>
          <span class="card-arrow">&rarr;</span>
        </div>
      </a>
      <a class="card" href="https://github.com/manufosela/workshop-make-a-simple-carousel-lit-element-web-component" target="_blank" rel="noopener noreferrer">
        <span class="tag">{t(locale, "tag.workshop")}</span>
        <h3>{t(locale, "learn.workshop.title")}</h3>
        <p>{t(locale, "learn.workshop.description")}</p>
        <div class="card-meta">
          <span class="label">{t(locale, "cta.openGithub")}</span>
          <span class="card-arrow">&rarr;</span>
        </div>
      </a>
      <a class="card" href="https://github.com/manufosela/generator-litelement-webcomponent" target="_blank" rel="noopener noreferrer">
        <span class="tag">{t(locale, "tag.tool")}</span>
        <h3>{t(locale, "learn.generator.title")}</h3>
        <p>{t(locale, "learn.generator.description")}</p>
        <div class="card-meta">
          <span class="label">{t(locale, "cta.openGithub")}</span>
          <span class="card-arrow">&rarr;</span>
        </div>
      </a>
    </div>
  </section>
</BaseLayout>
