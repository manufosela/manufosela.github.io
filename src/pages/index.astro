---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../data/site";
import { catalogs } from "../data/catalogs";
import { demos } from "../data/demos";

// Mark the first catalog as featured (wide) to break the grid symmetry
const [firstCatalog, ...restCatalogs] = catalogs;
---
<BaseLayout title={siteConfig.title} navTitle={siteConfig.title}>
  <section class="hero">
    <span class="eyebrow">Web Components / Design Systems</span>
    <h1 class="display-large">
      Design-focused<br />web components<br />
      <span class="mint-underline">built with care.</span>
    </h1>
    <p class="lead">{siteConfig.description}</p>
  </section>

  <section>
    <div class="section-header">
      <h2 class="headline-medium">Catalogs</h2>
      <p>Design systems, utilities, and focused component libraries. Each catalog has live demos, playgrounds, and accessibility built-in.</p>
    </div>
    <div class="bento">
      <a class="card wide featured" href={firstCatalog.href}>
        <span class="tag">Catalog / Flagship</span>
        <h3>{firstCatalog.title}</h3>
        <p>{firstCatalog.description}</p>
        <div class="card-meta">
          <span class="label">Explore</span>
          <span class="card-arrow">&rarr;</span>
        </div>
      </a>
      {restCatalogs.map((catalog) => (
        <a class="card" href={catalog.href}>
          <span class="tag">Catalog</span>
          <h3>{catalog.title}</h3>
          <p>{catalog.description}</p>
          <div class="card-meta">
            <span class="label">Explore</span>
            <span class="card-arrow">&rarr;</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  {demos.length > 0 && (
    <section>
      <div class="section-header">
        <h2 class="headline-medium">Example Apps</h2>
        <p>Complete apps built using components from the catalogs above — real-world usage examples.</p>
      </div>
      <div class="bento">
        {demos.map((demo) => (
          <a class="card" href={demo.href}>
            <span class="tag">{demo.category || "Demo"}</span>
            <h3>{demo.title}</h3>
            <p>{demo.description}</p>
            <div class="card-meta">
              <span class="label">Open</span>
              <span class="card-arrow">&rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
