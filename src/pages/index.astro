---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../data/site";
import { catalogs } from "../data/catalogs";
import { demos } from "../data/demos";

// Mark the first catalog as featured (wide) to break the grid symmetry
const [firstCatalog, ...restCatalogs] = catalogs;
---
<BaseLayout title={siteConfig.title} navTitle={siteConfig.title}>
  <section class="hero">
    <span class="eyebrow">Web Components / Design Systems</span>
    <h1 class="display-large">
      Design-focused<br />web components<br />
      <span class="mint-underline">built with care.</span>
    </h1>
    <p class="lead">{siteConfig.description}</p>
  </section>

  <section>
    <div class="section-header">
      <h2 class="headline-medium">Catalogs</h2>
      <p>Design systems, utilities, and focused component libraries. Each catalog has live demos, playgrounds, and accessibility built-in.</p>
    </div>
    <div class="bento">
      <a class="card wide featured" href={firstCatalog.href}>
        <span class="tag">Catalog / Flagship</span>
        <h3>{firstCatalog.title}</h3>
        <p>{firstCatalog.description}</p>
        <div class="card-meta">
          <span class="label">Explore</span>
          <span class="card-arrow">&rarr;</span>
        </div>
      </a>
      {restCatalogs.map((catalog) => (
        <a class="card" href={catalog.href}>
          <span class="tag">Catalog</span>
          <h3>{catalog.title}</h3>
          <p>{catalog.description}</p>
          <div class="card-meta">
            <span class="label">Explore</span>
            <span class="card-arrow">&rarr;</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  {demos.length > 0 && (
    <section>
      <div class="section-header">
        <h2 class="headline-medium">Example Apps</h2>
        <p>Complete apps built using components from the catalogs above — real-world usage examples.</p>
      </div>
      <div class="bento">
        {demos.map((demo) => (
          <a class="card" href={demo.href}>
            <span class="tag">{demo.category || "Demo"}</span>
            <h3>{demo.title}</h3>
            <p>{demo.description}</p>
            <div class="card-meta">
              <span class="label">Open</span>
              <span class="card-arrow">&rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <section>
    <div class="section-header">
      <h2 class="headline-medium">Learn</h2>
      <p>Guides and best practices from building 50+ production web components.</p>
    </div>
    <div class="bento">
      <a class="card wide featured" href="/guide/">
        <span class="tag">Guide</span>
        <h3>Building Web Components — A Practical Guide</h3>
        <p>Principles, patterns, and best practices: when to build, naming, data flow, accessibility, performance, and more.</p>
        <div class="card-meta">
          <span class="label">Read</span>
          <span class="card-arrow">&rarr;</span>
        </div>
      </a>
      <a class="card" href="https://github.com/manufosela/workshop-make-a-simple-carousel-lit-element-web-component" target="_blank" rel="noopener noreferrer">
        <span class="tag">Workshop</span>
        <h3>Make a Simple Carousel with Lit</h3>
        <p>Hands-on workshop walking through the creation of a carousel web component with LitElement, step by step.</p>
        <div class="card-meta">
          <span class="label">Open on GitHub</span>
          <span class="card-arrow">&rarr;</span>
        </div>
      </a>
      <a class="card" href="https://github.com/manufosela/generator-litelement-webcomponent" target="_blank" rel="noopener noreferrer">
        <span class="tag">Tool</span>
        <h3>generator-litelement-webcomponent</h3>
        <p>Yeoman generator (published on npm) to scaffold a new LitElement web component with a sensible structure out of the box.</p>
        <div class="card-meta">
          <span class="label">Open on GitHub</span>
          <span class="card-arrow">&rarr;</span>
        </div>
      </a>
    </div>
  </section>
</BaseLayout>
