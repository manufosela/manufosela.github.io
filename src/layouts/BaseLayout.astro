---
import { ViewTransitions } from "astro:transitions";
import TopNav from "../components/TopNav.astro";
import Footer from "../components/Footer.astro";
import LoadingOverlay from "../components/LoadingOverlay.astro";
import { t } from "../data/i18n.js";
import "../styles/theme.css";

const {
  title,
  navTitle,
  navLinks = [],
  locale = "en",
  translationPath = null,
} = Astro.props;

const currentPath = Astro.url.pathname;
const canonical = new URL(currentPath, Astro.site).href;

const stripLocale = (path) => {
  if (path === "/es" || path === "/es/") return "/";
  if (path.startsWith("/es/")) return path.slice(3);
  return path;
};
const addLocale = (path, loc) => {
  const base = stripLocale(path);
  if (loc === "en") return base;
  return `/es${base === "/" ? "/" : base}`;
};

const enPath = stripLocale(currentPath);
const esPath = addLocale(currentPath, "es");
const enHref = new URL(enPath, Astro.site).href;
const esHref = new URL(esPath, Astro.site).href;
---
<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="es" href={esHref} />
    <link rel="alternate" hreflang="x-default" href={enHref} />
    <script is:inline>
      (() => {
        const path = location.pathname;
        const isEs = path === "/es" || path === "/es/" || path.startsWith("/es/");
        const saved = localStorage.getItem("locale");
        if (saved) {
          if (saved === "es" && !isEs) {
            location.replace("/es" + (path === "/" ? "/" : path));
            return;
          }
          if (saved === "en" && isEs) {
            const stripped = path === "/es" || path === "/es/" ? "/" : path.slice(3);
            location.replace(stripped);
            return;
          }
          return;
        }
        const browserLang = (navigator.language || "en").toLowerCase();
        if (browserLang.startsWith("es") && !isEs) {
          location.replace("/es" + (path === "/" ? "/" : path));
        }
      })();
    </script>
    <ViewTransitions />
  </head>
  <body>
    <TopNav
      title={navTitle ?? title}
      links={navLinks}
      locale={locale}
      translationPath={translationPath}
      homeUrl={locale === "es" ? "/es/" : "/"}
    />
    <main>
      <div class="container">
        <slot />
      </div>
    </main>
    <Footer locale={locale} />
    <LoadingOverlay />
  </body>
</html>
